<!--
  Archivo: autopilot_base.launch

  Proposito general:
    Arranque base para observar navegacion Yahboom existente. Puede levantar
    bringup, navegacion por mapa y autopilot_monitor.py, pero no inicia el
    controlador seguro de Ghost.

  Informacion util:
    Usar este launch cuando se quiera probar solo observacion, LiDAR, move_base
    o estado de autopiloto. Para la capa mascota completa usar pet_robot.launch.
-->
<launch>
  <arg name="config" default="$(find yahboomcar_pet_behavior)/config/autopilot_base.yaml"/>
  <arg name="map" default="my_map"/>
  <arg name="use_rviz" default="true"/>
  <arg name="start_bringup" default="true"/>
  <arg name="start_navigation" default="true"/>
  <arg name="start_monitor" default="true"/>
  <arg name="enable_yolo_hooks" default="false"/>
  <arg name="detection_topic" default="/DetectMsg"/>
  <arg name="detection_msg_type" default="target_array"/>

  <!-- Base, LiDAR, odometria y TF. -->
  <include file="$(find yahboomcar_nav)/launch/laser_bringup.launch" if="$(arg start_bringup)"/>

  <!-- Stack de navegacion existente: map_server, AMCL, move_base y RViz. -->
  <include file="$(find yahboomcar_nav)/launch/yahboomcar_navigation.launch" if="$(arg start_navigation)">
    <arg name="map" value="$(arg map)"/>
    <arg name="use_rviz" value="$(arg use_rviz)"/>
  </include>

  <!-- Monitor pasivo. No publica cmd_vel ni cancela goals. -->
  <node pkg="yahboomcar_pet_behavior"
        type="autopilot_monitor.py"
        name="autopilot_monitor"
        output="screen"
        if="$(arg start_monitor)">
    <rosparam file="$(arg config)" command="load"/>
    <param name="map" type="string" value="$(arg map)"/>
    <param name="use_rviz" type="bool" value="$(arg use_rviz)"/>
    <param name="enable_yolo_hooks" type="bool" value="$(arg enable_yolo_hooks)"/>
    <param name="detection_topic" type="string" value="$(arg detection_topic)"/>
    <param name="detection_msg_type" type="string" value="$(arg detection_msg_type)"/>
  </node>
</launch>
